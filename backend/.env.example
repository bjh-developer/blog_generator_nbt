# Copy to .env and fill. Cloudflare creds + Firecrawl required for live runs.
# OPENROUTER_API_KEY is only used for the fallback model (owl-alpha).
OPENROUTER_API_KEY=
# Primary discovery + scrape source (Firecrawl v2 /search)
FIRECRAWL_API_KEY=

# Cloudflare Workers AI (active fast/general roles)
CF_ACCOUNT_ID=
CF_API_TOKEN=

# Model routing — fast/general on Cloudflare (@cf/*), fallback on OpenRouter
MODEL_FAST=@cf/meta/llama-3.2-3b-instruct
MODEL_GENERAL=@cf/mistralai/mistral-small-3.1-24b-instruct
MODEL_REASONING=@cf/mistralai/mistral-small-3.1-24b-instruct
MODEL_FALLBACK=openrouter/owl-alpha

# Throttle / quota — tune for Cloudflare per-model limits (was OpenRouter 18 rpm)
LLM_RPM=18
PROMPT_CACHE=0

# Verification
VERIFY_THRESHOLD=0.6
USE_EMBEDDINGS=0

# Dev fixture — skip live Firecrawl calls (set to fixture path, leave blank for live)
# USE_FIXTURE=data/fixtures/firecrawl_luma.json
