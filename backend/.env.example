# Copy to .env and fill. Both keys required for live runs.
OPENROUTER_API_KEY=
# Primary discovery + scrape source (Firecrawl v2 /search)
FIRECRAWL_API_KEY=

# Model routing (free OpenRouter models)
MODEL_FAST=openrouter/owl-alpha
MODEL_GENERAL=openrouter/owl-alpha
MODEL_REASONING=openrouter/owl-alpha
MODEL_FALLBACK=openrouter/owl-alpha

# Throttle / quota
LLM_RPM=18
PROMPT_CACHE=0

# Verification
VERIFY_THRESHOLD=0.6
USE_EMBEDDINGS=0

# Dev fixture — skip live Firecrawl calls (set to fixture path, leave blank for live)
# USE_FIXTURE=data/fixtures/firecrawl_airbnb.json
