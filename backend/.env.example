# Copy to .env and fill. Both keys required for live runs.
OPENROUTER_API_KEY=
# Primary discovery + scrape source (Firecrawl v2 /search)
FIRECRAWL_API_KEY=

# Model routing (free OpenRouter models). FAST = triage/classify — keep it a
# small NON-reasoning model. Reasoning models (r1, nemotron-ultra) are slow here.
MODEL_FAST=meta-llama/llama-3.3-70b-instruct:free
MODEL_GENERAL=deepseek/deepseek-chat-v3-0324:free
MODEL_REASONING=deepseek/deepseek-r1:free
MODEL_FALLBACK=meta-llama/llama-3.3-70b-instruct:free

# Throttle / quota
LLM_RPM=18
PROMPT_CACHE=1
# structured outputs (decode-time JSON Schema). Keep 0 for most free OSS models;
# set 1 only for models that support it (e.g. gemini-flash). Repair pipeline
# handles broken JSON either way.
LLM_JSON_SCHEMA=0

# Verification
VERIFY_THRESHOLD=0.6
USE_EMBEDDINGS=0
